                  "name": "PBFA97CFB590B2093"
                },
                "group": "prometheus",
                "kind": "DataQuery",
                "spec": {
                  "editorMode": "code",
                  "expr": "sum(rate(pg_stat_database_blks_read_total{}[$__rate_interval]) + rate(pg_stat_database_blks_hit_total{}[$__rate_interval])) * avg(pg_block_size_bytes)\n",
                  "instant": false,
                  "legendFormat": "postgres memory footprint ( (total blk hit + total blk read) * blk size )",
                  "range": true
                },
                "version": "v0"
              },
              "refId": "postgres foot print"
            }
          }
        ],
        "queryOptions": {},
        "transformations": []
      }
