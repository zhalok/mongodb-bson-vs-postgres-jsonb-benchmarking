                "group": "prometheus",
                "kind": "DataQuery",
                "spec": {
                  "editorMode": "code",
                  "expr": "sum(rate(mongo_wt_cache_requested_pages_total{ }[$__rate_interval])) * avg(mongo_wt_leaf_page_max_bytes{ })",
                  "fromExploreMetrics": true,
                  "interval": "",
                  "legendFormat": "mongodb memory footprint (total pages requested * page size)",
                  "range": true
                },
                "version": "v0"
              },
              "refId": "mongodb footprint"
            }
          },
          {
            "kind": "PanelQuery",
            "spec": {
              "hidden": false,
              "query": {
