{
  "kind": "Panel",
  "spec": {
    "id": 3,
    "title": "Memory Footprint MongoDB vs PostgreSQL",
    "description": "",
    "links": [],
    "data": {
      "kind": "QueryGroup",
      "spec": {
        "queries": [
          {
            "kind": "PanelQuery",
            "spec": {
              "query": {
                "kind": "DataQuery",
                "group": "prometheus",
                "version": "v0",
                "datasource": {
                  "name": "PBFA97CFB590B2093"
                },
                "spec": {
                  "editorMode": "code",
                  "expr": "sum(rate(mongo_wt_cache_requested_memory_footprint_bytes{ }[$__rate_interval]))",
                  "fromExploreMetrics": true,
                  "interval": "",
                  "legendFormat": "mongodb memory footprint (total pages requested * page size)",
                  "range": true
                }
              },
              "refId": "mongodb footprint",
              "hidden": false
            }
          },
          {
            "kind": "PanelQuery",
            "spec": {
              "query": {
                "kind": "DataQuery",
                "group": "prometheus",
                "version": "v0",
                "datasource": {
                  "name": "PBFA97CFB590B2093"
                },
                "spec": {
                  "editorMode": "code",
                  "expr": "sum(rate(pg_stat_database_memory_footprint_bytes{ }[$__rate_interval]))",
                  "instant": false,
                  "legendFormat": "postgres memory footprint ( (total blk hit + total blk read) * blk size )",
                  "range": true
                }
              },
              "refId": "postgres foot print",
              "hidden": false
            }
          }
        ],
        "transformations": [],
        "queryOptions": {}
      }
    },
    "vizConfig": {
