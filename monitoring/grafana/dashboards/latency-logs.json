{
  "title": "Request Latency (from logs)",
  "uid": "latency-logs",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Read (GET) p90 Latency (ms)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "quantile_over_time(0.90, {container=~\"server-postgres|server-mongo\"} | regexp `(?P<method>\\S+) (?P<url>\\S+) (?P<status>\\d+) (?P<duration>\\d+)ms` | method=\"GET\" | unwrap duration [$__auto]) by (container)"
        }
      ]
    },
    {
      "id": 2,
      "title": "Write (POST) p90 Latency (ms)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "quantile_over_time(0.90, {container=~\"server-postgres|server-mongo\"} | regexp `(?P<method>\\S+) (?P<url>\\S+) (?P<status>\\d+) (?P<duration>\\d+)ms` | method=\"POST\" | unwrap duration [$__auto]) by (container)"
        }
      ]
    },
    {
      "id": 3,
      "title": "Request Rate by Status and Method",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "sum by (container, method, status) (rate({container=~\"server-postgres|server-mongo\"} | regexp `(?P<method>\\S+) (?P<url>\\S+) (?P<status>\\d+) (?P<duration>\\d+)ms` [$__auto]))"
        }
      ]
    },
    {
      "id": 4,
      "title": "Raw Logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "{container=~\"server-postgres|server-mongo\"}"
        }
      ]
    }
  ]
}
